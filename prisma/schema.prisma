generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OnboardingState {
  candidate_created
  packet_assigned
  in_progress
  pending_hr_review
  approved
  employee_active
}

enum TaskStatus {
  draft
  submitted
  approved
  rejected
}

enum TaskType {
  personal_info
  government_forms
  document_upload
  policy_acknowledgment
  training_acknowledgment
  e_signature
  role_confirmation
  background_check
}

enum EmploymentType {
  full_time
  part_time
  contract
  intern
}

enum UserRole {
  admin
  hr
  manager
  employee
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  domain      String?  @unique
  settings    String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users              User[]
  candidates         Candidate[]
  onboardingPackets  OnboardingPacket[]
  locations          Location[]
  departments        Department[]
  roles              TenantRole[]
  auditLogs          AuditLog[]
  employees          Employee[]
  onboardings        EmployeeOnboarding[]
  tasks              OnboardingTask[]
  documents          Document[]
  eSignEnvelopes     ESignEnvelope[]
  payPeriods         PayPeriod[]
  dailyNotes         DailyNote[]
  marRecords         MedicationAdministrationRecord[]
  posts              Post[]
  conversations      Conversation[]
  attendanceRecords  AttendanceRecord[]
  patients           Patient[]
  timeOffRequests    TimeOffRequest[]
  timeOffBalances    TimeOffBalance[]
  timeOffLogs        TimeOffLog[]
  holidays           Holiday[]
  appointments       Appointment[]
  sharedLinks        SharedLink[]
}

model User {
  id            String   @id @default(uuid())
  tenantId      String
  email         String
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee?
  posts         Post[]
  postReactions PostReaction[]
  postComments  PostComment[]
  conversations  ConversationParticipant[]
  sentMessages   Message[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, email])
}

model Employee {
  id              String   @id @default(uuid())
  userId          String   @unique
  tenantId        String
  employeeNumber  String?
  departmentId    String?
  locationId      String?
  tenantRoleId    String?
  startDate       DateTime
  onboardingStatus OnboardingState @default(candidate_created)
  canClockIn      Boolean  @default(false)
  hourlyRate      Float    @default(15.00)
  overtimeRate    Float    @default(22.50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department      Department?  @relation(fields: [departmentId], references: [id])
  location        Location?    @relation(fields: [locationId], references: [id])
  tenantRole      TenantRole? @relation(fields: [tenantRoleId], references: [id])
  timeEntries     TimeEntry[]
  dailyNotes      DailyNote[]
  marRecords      MedicationAdministrationRecord[]
  payrollRecords  PayrollRecord[]
  documents       Document[]
  attendanceRecords AttendanceRecord[]
  patientAssignments PatientStaff[]
  timeOffRequests TimeOffRequest[]
  timeOffBalances TimeOffBalance[]
  timeOffLogs     TimeOffLog[]
  assignedAppointments Appointment[]

  @@index([tenantId])
  @@index([tenantId, userId])
}

model Location {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]
  candidates Candidate[]
  holidayAssignments HolidayAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Department {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]
  candidates Candidate[]
  holidayAssignments HolidayAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TenantRole {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  permissions String     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees   Employee[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model OnboardingPacket {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  tasks       String     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments EmployeeOnboarding[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Candidate {
  id              String           @id @default(uuid())
  tenantId        String
  firstName       String
  lastName        String
  email           String
  phone           String?
  position        String
  locationId      String?
  departmentId    String?
  employmentType  EmploymentType
  startDate       DateTime
  state           OnboardingState  @default(candidate_created)
  rejectedReason  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  location        Location?          @relation(fields: [locationId], references: [id])
  department      Department?        @relation(fields: [departmentId], references: [id])
  onboarding      EmployeeOnboarding?
  documents       Document[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, state])
  @@index([tenantId, email])
}

model EmployeeOnboarding {
  id                  String            @id @default(uuid())
  candidateId         String            @unique
  packetId            String
  tenantId            String
  secureToken         String            @unique @default(uuid())
  tokenExpiresAt      DateTime
  progressPercent     Int               @default(0)
  currentState        OnboardingState   @default(packet_assigned)
  completedAt         DateTime?
  activatedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  candidate           Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  packet              OnboardingPacket  @relation(fields: [packetId], references: [id])
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  taskStatuses        EmployeeOnboardingTaskStatus[]

  @@index([tenantId])
  @@index([secureToken])
  @@index([tenantId, candidateId])
}

model OnboardingTask {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  type        TaskType
  description String?
  isRequired  Boolean  @default(true)
  order       Int      @default(0)
  config      String     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant                              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  statuses    EmployeeOnboardingTaskStatus[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, type])
}

model EmployeeOnboardingTaskStatus {
  id                    String     @id @default(uuid())
  onboardingId          String
  taskId                String
  status                TaskStatus @default(draft)
  submissionData        String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  reviewComment         String?
  reviewedByUserId      String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  onboarding             EmployeeOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  task                  OnboardingTask     @relation(fields: [taskId], references: [id])

  @@unique([onboardingId, taskId])
  @@index([onboardingId])
  @@index([taskId])
  @@index([onboardingId, status])
}

model Document {
  id              String   @id @default(uuid())
  candidateId     String?
  employeeId      String?
  tenantId        String
  name            String
  type            String
  fileUrl         String
  fileSize        Int?
  mimeType        String?
  expiresAt       DateTime?
  uploadedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  candidate       Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  employee        Employee?  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([candidateId])
  @@index([employeeId])
  @@index([tenantId, expiresAt])
}

model ESignEnvelope {
  id              String   @id @default(uuid())
  candidateId     String
  tenantId        String
  taskStatusId    String?
  envelopeId      String?
  provider        String?
  status          String   @default("pending")
  documentUrl     String?
  signedDocumentUrl String?
  signatureHash   String?
  signedAt        DateTime?
  signerName      String?
  signerEmail     String?
  ipAddress       String?
  payloadJson     String?
  sentAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([candidateId])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String?
  action      String
  entityType  String
  entityId    String?
  oldValues   String?
  newValues   String?
  metadata    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model TimeEntry {
  id          String    @id @default(uuid())
  employeeId  String
  clockIn     DateTime
  clockOut    DateTime?
  breakMinutes Int      @default(0)
  totalMinutes Int?
  status      TimesheetStatus @default(submitted)
  approvedAt  DateTime?
  approvedBy   String?
  rejectionReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payPeriod   PayPeriod? @relation(fields: [payPeriodId], references: [id])
  payPeriodId String?

  @@index([employeeId])
  @@index([employeeId, clockIn])
  @@index([payPeriodId])
}

enum TimesheetStatus {
  draft
  submitted
  approved
  rejected
}

enum PayPeriodStatus {
  open
  locked
  calculated
  exported
}

model PayPeriod {
  id              String          @id @default(uuid())
  tenantId        String
  name            String
  startDate       DateTime
  endDate         DateTime
  status          PayPeriodStatus @default(open)
  lockedAt        DateTime?
  lockedBy        String?
  calculatedAt    DateTime?
  exportedAt      DateTime?
  exportProvider  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timeEntries     TimeEntry[]
  payrollRecords  PayrollRecord[]

  @@index([tenantId])
  @@index([tenantId, status])
}

enum PayrollStatus {
  calculated
  exported
}

model PayrollRecord {
  id              String        @id @default(uuid())
  payPeriodId     String
  employeeId      String
  totalHours      Float
  breakDeductions Float
  overtimeHours  Float
  overtimePay     Float
  regularPay      Float
  grossPay        Float
  payRate         Float
  status          PayrollStatus @default(calculated)
  calculatedAt    DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  payPeriod       PayPeriod     @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payPeriodId, employeeId])
  @@index([payPeriodId])
  @@index([employeeId])
}

enum DailyNoteStatus {
  draft
  submitted
  locked
}

model DailyNote {
  id              String          @id @default(uuid())
  tenantId        String
  employeeId      String
  participantId   String?
  date            DateTime
  content         String
  attachments     String          @default("[]")
  status          DailyNoteStatus @default(draft)
  lockedAt        DateTime?
  lockedBy        String?
  reviewedAt      DateTime?
  reviewedBy      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
  @@index([tenantId])
  @@index([employeeId])
  @@index([participantId])
  @@index([tenantId, status])
}

enum MARStatus {
  scheduled
  given
  missed
  refused
  locked
}

model MedicationAdministrationRecord {
  id              String        @id @default(uuid())
  tenantId        String
  employeeId      String
  participantId   String?
  medicationName  String
  scheduledTime   DateTime
  outcome         MARStatus
  outcomeTime     DateTime?
  reasonNotGiven  String?
  administeredBy  String?
  lockedAt        DateTime?
  lockedBy        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
  @@index([participantId])
  @@index([tenantId, outcome])
}

model Post {
  id          String   @id @default(uuid())
  tenantId    String
  authorId    String
  content     String
  imageUrl    String?
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions   PostReaction[]
  comments    PostComment[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model PostReaction {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  type      String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId])
  @@index([userId])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model Conversation {
  id        String   @id @default(uuid())
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages  Message[]

  @@index([tenantId])
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, createdAt])
}

model AttendanceRecord {
  id              String            @id @default(uuid())
  employeeId      String
  tenantId        String
  clockIn         DateTime
  clockOut        DateTime?
  workDate        DateTime
  totalMinutes    Int?
  breakMinutes    Int               @default(0)
  deviceType      String?
  ipAddress       String?
  latitude        Float?
  longitude       Float?
  isLate          Boolean           @default(false)
  isEarlyLeave    Boolean           @default(false)
  isHolidayWork   Boolean           @default(false)
  isOvertime      Boolean           @default(false)
  status          AttendanceStatus  @default(active)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  employee        Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adjustments     AttendanceAdjustment[]
  logs            AttendanceLog[]

  @@index([tenantId])
  @@index([employeeId])
  @@index([tenantId, workDate])
  @@index([employeeId, workDate])
  @@index([tenantId, status])
}

enum AttendanceStatus {
  active
  completed
  flagged
  adjusted
  missing
}

model AttendanceAdjustment {
  id              String   @id @default(uuid())
  attendanceId    String
  adjustedBy      String
  adjustedAt      DateTime @default(now())
  clockIn         DateTime?
  clockOut        DateTime?
  totalMinutes    Int?
  reason          String
  previousValues  String
  newValues       String
  createdAt       DateTime @default(now())

  attendance      AttendanceRecord @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([adjustedBy])
}

model AttendanceLog {
  id              String   @id @default(uuid())
  attendanceId    String
  action          String
  performedBy     String
  performedAt     DateTime @default(now())
  ipAddress       String?
  userAgent       String?
  details         String?
  createdAt       DateTime @default(now())

  attendance      AttendanceRecord @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([performedBy])
  @@index([attendanceId, action])
}

model Patient {
  id              String   @id @default(uuid())
  tenantId        String
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  gender          String
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  emergencyName   String?
  emergencyPhone  String?
  emergencyRelation String?
  bloodType       String?
  allergies       String?
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medicalReports  MedicalReport[]
  medicines       MedicineHistory[]
  appointments    Appointment[]
  staffAssignments PatientStaff[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([lastName, firstName])
}

model PatientStaff {
  id          String   @id @default(uuid())
  patientId   String
  staffId     String
  assignedAt  DateTime @default(now())
  isPrimary   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  patient     Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  staff       Employee   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([patientId, staffId])
  @@index([patientId])
  @@index([staffId])
}

model MedicalReport {
  id              String   @id @default(uuid())
  patientId       String
  reportDate      DateTime
  doctorName      String
  diagnosis       String?
  treatment       String?
  notes           String?
  fileUrl         String?
  fileType        String?
  fileSize        Int?
  isApproved      Boolean  @default(false)
  approvedAt      DateTime?
  approvedBy      String?
  immutable       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([patientId, reportDate])
  @@index([isApproved])
}

model MedicineHistory {
  id              String         @id @default(uuid())
  patientId       String
  medicineName    String
  dosage          String
  frequency       String
  startDate       DateTime
  endDate         DateTime?
  prescribedBy    String
  status          MedicineStatus @default(active)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([patientId, status])
}

enum MedicineStatus {
  active
  stopped
  completed
  paused
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  tenantId        String
  staffId         String?
  appointmentDate DateTime
  duration        Int               @default(30)
  appointmentType String
  status          AppointmentStatus @default(scheduled)
  reason          String?
  notes           String?
  cancelReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff           Employee? @relation(fields: [staffId], references: [id])

  @@index([tenantId])
  @@index([patientId])
  @@index([staffId])
  @@index([tenantId, appointmentDate])
  @@index([status])
}

enum AppointmentStatus {
  scheduled
  confirmed
  in_progress
  completed
  canceled
  no_show
}

model TimeOffRequest {
  id              String           @id @default(uuid())
  employeeId      String
  tenantId        String
  type            TimeOffType
  startDate       DateTime
  endDate         DateTime
  totalDays       Float
  reason          String?
  status          TimeOffStatus    @default(pending)
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewComment   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
  @@index([tenantId, status])
  @@index([startDate, endDate])
}

enum TimeOffType {
  annual
  sick
  unpaid
  parental
  bereavement
  other
}

enum TimeOffStatus {
  pending
  approved
  rejected
  canceled
}

model TimeOffBalance {
  id              String      @id @default(uuid())
  employeeId      String
  tenantId        String
  year            Int
  type            TimeOffType
  totalDays       Float
  usedDays        Float       @default(0)
  pendingDays     Float       @default(0)
  carryOverDays   Float       @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, type])
  @@index([employeeId])
  @@index([tenantId, year])
}

model TimeOffLog {
  id              String   @id @default(uuid())
  timeOffRequestId String?
  balanceId       String?
  employeeId      String
  tenantId        String
  action          String
  performedBy     String
  performedAt     DateTime @default(now())
  previousValues  String?
  newValues       String?
  reason          String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
  @@index([timeOffRequestId])
  @@index([performedAt])
}

model Holiday {
  id              String      @id @default(uuid())
  tenantId        String
  name            String
  date            DateTime
  endDate         DateTime?
  type            HolidayType
  description     String?
  isRecurring     Boolean     @default(false)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments     HolidayAssignment[]

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, isActive])
}

enum HolidayType {
  national
  company
  regional
  optional
}

model HolidayAssignment {
  id          String   @id @default(uuid())
  holidayId   String
  departmentId String?
  locationId  String?
  region      String?
  createdAt   DateTime @default(now())

  holiday     Holiday    @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  department  Department? @relation(fields: [departmentId], references: [id])
  location    Location?  @relation(fields: [locationId], references: [id])

  @@index([holidayId])
  @@index([departmentId])
  @@index([locationId])
}

model SharedLink {
  id          String   @id @default(uuid())
  tenantId    String
  entityType  String
  entityId    String
  token       String   @unique
  expiresAt   DateTime
  createdBy   String
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
  @@index([expiresAt])
}
