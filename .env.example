# ===========================================
# Backend Environment Variables
# ===========================================
# Copy this file to .env or set these
# in your deployment platform.
# ===========================================

# ===========================================
# Database - REQUIRED FOR PRODUCTION
# ===========================================
# For Vercel/Render deployment, use Turso (libSQL):
DATABASE_URL="file:./dev.db"

# Turso Example (for serverless):
# DATABASE_URL="libsql://your-database.turso.io"
# DATABASE_AUTH_TOKEN="your-auth-token"

# ===========================================
# Authentication
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ===========================================
# CORS & URLs
# ===========================================
CORS_ORIGIN="http://localhost:5173"
APP_URL="http://localhost:3000"
FRONTEND_URL="https://your-frontend.vercel.app"

# ===========================================
# Demo Accounts (SEED)
# ===========================================
# Set to "true" to auto-create demo accounts on startup
SEED_DEMO="true"
DEMO_EMAIL="demo@timegrid.app"
DEMO_PASSWORD="demo123"
DEMO_HR_EMAIL="hr@timegrid.app"
DEMO_HR_PASSWORD="hr123"
DEMO_EMPLOYEE_EMAIL="employee@timegrid.app"
DEMO_EMPLOYEE_PASSWORD="employee123"

# ===========================================
# Email (Optional)
# ===========================================
EMAIL_PROVIDER="console"
EMAIL_FROM="noreply@timegrid.com"

# ===========================================
# AWS (Optional - for file storage)
# ===========================================
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ===========================================
# SMTP (Optional - for emails)
# ===========================================
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""

# ===========================================
# Storage (Optional)
# ===========================================
STORAGE_PROVIDER="local"
S3_BUCKET=""
S3_REGION="us-east-1"
